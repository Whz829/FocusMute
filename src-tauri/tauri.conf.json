{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FocusMute",
  "version": "1.0.0",
  "identifier": "com.codex.focusmute",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "FocusMute",
        "decorations": false,
        "shadow": true,
        "width": 1220,
        "height": 780,
        "minWidth": 860,
        "minHeight": 600,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "OpenSource (MIT)",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
